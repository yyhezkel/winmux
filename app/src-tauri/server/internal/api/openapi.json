{
  "openapi": "3.1.0",
  "info": {
    "title": "winmux-server",
    "version": "2.0.0",
    "description": "winmux server daemon API. Desktop + mobile clients speak this surface. Streaming (WebSocket) frames are described separately in asyncapi.json (PHASE-77-DESIGN §4.4). Hand-authored in S2; auto-generation via huma is scheduled for S4."
  },
  "servers": [{ "url": "/" }],
  "security": [{ "bearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "Version": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "api_versions": { "type": "array", "items": { "type": "integer" } },
          "frame_version": { "type": "integer" }
        }
      },
      "FileEntry": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["dir", "file"] },
          "size": { "type": "integer", "format": "int64" },
          "modified": { "type": "integer", "format": "int64", "description": "unix seconds" }
        }
      },
      "FileList": {
        "type": "object",
        "properties": {
          "cwd": { "type": "string" },
          "entries": { "type": "array", "items": { "$ref": "#/components/schemas/FileEntry" } }
        }
      },
      "UploadResult": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "size": { "type": "integer", "format": "int64" },
          "sha256": { "type": "string" }
        }
      },
      "ClientInfo": {
        "type": "object",
        "properties": {
          "client_id": { "type": "string" },
          "device_name": { "type": "string" },
          "log_dir": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "latest_entry": { "type": "integer", "format": "int64" }
        }
      }
    }
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Liveness probe (unauthenticated)",
        "security": [],
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/api/version": {
      "get": {
        "summary": "Version + capability negotiation (unauthenticated)",
        "security": [],
        "responses": {
          "200": {
            "description": "version info",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Version" } } }
          }
        }
      }
    },
    "/api/v2/insights/current": {
      "get": {
        "summary": "Latest cached metrics snapshot",
        "responses": { "200": { "description": "snapshot (cpu/mem/disk/net/docker/top)" }, "401": { "description": "unauthorized" } }
      }
    },
    "/api/v2/insights/history": {
      "get": {
        "summary": "Metric history",
        "parameters": [
          { "name": "metric", "in": "query", "schema": { "type": "string" } },
          { "name": "since", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "points" }, "401": { "description": "unauthorized" } }
      }
    },
    "/api/v2/insights/hygiene": {
      "get": {
        "summary": "Duplicate port-watchers + orphan Claude sessions",
        "responses": { "200": { "description": "hygiene report" }, "401": { "description": "unauthorized" } }
      }
    },
    "/api/v2/files/list": {
      "get": {
        "summary": "List a directory (sandboxed to the server's files root)",
        "parameters": [
          { "name": "path", "in": "query", "schema": { "type": "string" } },
          { "name": "depth", "in": "query", "schema": { "type": "integer", "enum": [1, 2] } }
        ],
        "responses": {
          "200": { "description": "listing", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FileList" } } } },
          "403": { "description": "path escapes sandbox" },
          "404": { "description": "not found" }
        }
      }
    },
    "/api/v2/files/read": {
      "get": {
        "summary": "Read up to max_bytes of a file (raw bytes; X-Winmux-Truncated header)",
        "parameters": [
          { "name": "path", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "max_bytes", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "file bytes", "content": { "application/octet-stream": {} } }, "403": {}, "404": {} }
      }
    },
    "/api/v2/files/upload": {
      "post": {
        "summary": "Upload a file (multipart form; ?path= destination)",
        "parameters": [{ "name": "path", "in": "query", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" } } } } }
        },
        "responses": {
          "200": { "description": "written", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UploadResult" } } } },
          "403": {}, "413": { "description": "too large" }
        }
      }
    },
    "/api/v2/files/download": {
      "get": {
        "summary": "Download a file (octet-stream, attachment)",
        "parameters": [{ "name": "path", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "file", "content": { "application/octet-stream": {} } }, "404": {} }
      }
    },
    "/api/v2/files/delete": {
      "delete": {
        "summary": "Delete a file or empty directory",
        "parameters": [{ "name": "path", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "deleted" }, "403": {}, "404": {} }
      }
    },
    "/api/v2/logs/list": {
      "get": {
        "summary": "List log clients (per-device + the server pseudo-client)",
        "responses": {
          "200": { "description": "clients", "content": { "application/json": { "schema": { "type": "object", "properties": { "clients": { "type": "array", "items": { "$ref": "#/components/schemas/ClientInfo" } } } } } } }
        }
      }
    },
    "/api/v2/logs/read": {
      "get": {
        "summary": "Read the tail of a client's log",
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "file", "in": "query", "schema": { "type": "string" } },
          { "name": "tail", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "lines" }, "400": { "description": "invalid id/file" } }
      }
    },
    "/api/v2/logs/stream": {
      "get": {
        "summary": "Server-Sent Events tail of a client's log (event: line)",
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "file", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "text/event-stream", "content": { "text/event-stream": {} } } }
      }
    }
  }
}
